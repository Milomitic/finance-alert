# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node
node_modules/
frontend/dist/

# Local data
backend/data/*.db
backend/data/*.db.*
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm
backend/data/*.csv
backend/data/logs/
# Runtime state — persistent circuit-breaker timestamps + cached upstream
# payloads (regenerated on demand, machine-specific, not source of truth)
backend/data/breakers.json
backend/data/source_metrics.json
backend/data/scheduler_metrics.json
backend/data/ff_calendar.xml
# Stray repo-root /data — sometimes created by scripts run from the wrong
# cwd (worktree edge case). Belongs nowhere in git, ever.
/data/

# Env
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# OS
Thumbs.db

.claude/
# Anchored to repo root: ignore only a stray top-level finance-alert/ checkout,
# NOT charts/finance-alert/ (the Helm chart, which must be tracked).
/finance-alert/
.superpowers/

# Runtime logs (emitted by uvicorn started from repo root)
data/logs/

# Terraform: never commit state (holds resource data incl. sensitive attrs),
# the provider plugin cache, or the env-specific tfvars (OCIDs). The
# *.example and *.tf files ARE tracked.
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
**/terraform.tfvars
crash.log

# A1 capacity-retry bot runtime log + last-apply scratch
infra/oci/*.log
infra/oci/.last-apply.out

# Worktrees (created by superpowers using-git-worktrees skill)
.worktrees/

# Local scratch/build dirs created by Claude tooling
.pptx-build/

# scoring non-regression gate snapshots (transient)
backend/tests/_ranking_*.json
