# ─── Core ────────────────────────────────────────────────────────────
APP_ENV=development
DATABASE_URL=sqlite:///./data/app.db
SECRET_KEY=                       # auto-generated by `just install` if empty
SESSION_COOKIE_NAME=finance_alert_session
SESSION_MAX_AGE_DAYS=7
LOG_LEVEL=INFO

# ─── Auth (single user) ──────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=              # set via `just set-password`
PUBLIC_BASE_URL=http://localhost:8000

# ─── Telegram digest (optional) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DELIVERY_MODE=digest
DIGEST_HOUR=8
DIGEST_MINUTE=0

# ─── Nightly scan (Europe/Rome) ──────────────────────────────────────
SCAN_HOUR=23
SCAN_MINUTE=30

# ─── External data sources (all optional — graceful degradation) ─────
# FRED — macro series for the calendar. Free: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Finnhub — earnings actuals + company news + analyst upgrade/downgrade +
# recommendation buckets (fallbacks when yfinance is stale/empty).
# Free 60 req/min: https://finnhub.io
FINNHUB_API_KEY=
# Marketaux — news fallback (last resort). Free 100 req/day; the service
# self-limits (12h cache + 85/day soft budget + circuit breaker).
# https://www.marketaux.com
MARKETAUX_API_KEY=

# ─── Feature flags (set in the process environment, not strictly .env) ─
# SCORE_ENGINE_XS=1   # enable cross-sectional (sector-relative) scoring.
#                     # Default OFF — IC validation showed it degrades the
#                     # predictive signal on this universe. See scoring docs.
